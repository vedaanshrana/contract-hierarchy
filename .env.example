# ===========================================================================
# ENVIRONMENT TEMPLATE  —  copy this file to ".env" and fill in real values.
#
#   Windows (PowerShell):   Copy-Item .env.example .env
#   macOS / Linux:          cp .env.example .env
#
# The ".env" file is gitignored and must NEVER be committed or shared.
# ===========================================================================

# Which backend to call:
#   openai  -> api.openai.com via the OpenAI SDK (default, for local dev)
#   fiserv  -> the Fiserv Foundation API gateway (use this in the Fiserv VDI)
OPENAI_BACKEND=openai

# ---------------------------------------------------------------------------
# Used when OPENAI_BACKEND=openai  (and optionally as the gateway api-key below)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-key-here

# Optional: only for an OpenAI-compatible corporate proxy on the "openai" path.
# OPENAI_BASE_URL=https://your-corporate-openai-gateway.example.com/v1

# ---------------------------------------------------------------------------
# Used only when OPENAI_BACKEND=fiserv
# ---------------------------------------------------------------------------
# Full Foundation API chat/completions URL, including the ?api-version= query.
FOUNDATION_API_URL=https://dev-cst-cognitive-service.onefiserv.net/FoundationAPI/openai/deployments/default/chat/completions?api-version=2025-03-01-preview
FISERV_EMAIL=your.name@fiserv.com
# X-Purpose tags pick the model family at the Foundation gateway:
#   GPT-5-class models (gpt-5.x)              -> FISERV_PURPOSE_GPT5
#   everything else (gpt-4.1, gpt-4o-mini)    -> FISERV_PURPOSE_GPT4
FISERV_PURPOSE_GPT5=GPT5.1Purpose
FISERV_PURPOSE_GPT4=GPT4.1Purpose
# If the gateway also requires a subscription/api key, set OPENAI_API_KEY above;
# it is sent as the "api-key" header. (Confirm the exact auth header with Fiserv.)
